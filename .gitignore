# ============================================================
# KZ Downloader — .gitignore
# ============================================================

# ------------------------------------------------------------
# Folders to exclude
# ------------------------------------------------------------

# Agent runtime data (LLM / AI agent workspace)
.agents/

# Git internals (should never be committed inside a repo)
.git/

# JSON data / config dumps
JSONs/

# Chromium / browser profile used by the downloader
kz_browser_profile/

# ------------------------------------------------------------
# Deployment & build artifacts
# ------------------------------------------------------------

# Deploy timestamp / marker file
.deploy_stamp

# ------------------------------------------------------------
# Logs & temporary files
# ------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.swp
*~

# ------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS (in case the project ever touches a Mac)
.DS_Store
.AppleDouble
.LSOverride

# ------------------------------------------------------------
# Python (kz_scanner.py)
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.spec

# ------------------------------------------------------------
# PowerShell (KZ_Deploy.ps1)
# ------------------------------------------------------------
# PowerShell transcript logs
*_transcript_*.txt

# ------------------------------------------------------------
# Node / npm (if a frontend or toolchain is added later)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# Editor / IDE files
# ------------------------------------------------------------

# VS Code (CHANGELOG.md and README.md have VS Code icons visible)
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace
